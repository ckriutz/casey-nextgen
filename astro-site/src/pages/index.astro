---
import '../styles/global.css';
const currentYear = new Date().getFullYear();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Casey Kriutzfield</title>
	</head>
	<body class="min-h-screen">
		<main class="mx-auto max-w-5xl px-6 py-16 md:py-24">
			<section class="grid gap-8 rounded-2xl border border-slate-800 bg-surface p-8 md:grid-cols-[1fr_auto] md:items-center">
				<div>
					<p class="text-sm uppercase tracking-[0.2em] text-muted">CaseyKriutzfield.com</p>
					<h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">Casey Kriutzfield</h1>
					<p class="mt-4 max-w-2xl text-muted">
						Application Development Manager and software engineer focused on practical cloud architecture and delivery.
					</p>
					<div class="mt-6 flex flex-wrap gap-4 text-sm">
						<a class="text-accent hover:underline" href="https://www.linkedin.com/in/caseykriutzfield">LinkedIn</a>
						<a class="text-accent hover:underline" href="https://github.com/ckriutz">GitHub</a>
						<a class="text-accent hover:underline" href="https://twitter.com/ckriutzfield">X / Twitter</a>
					</div>
				</div>
				<img
					src="/images/profile-placeholder.svg"
					alt="Profile placeholder for Casey Kriutzfield"
					class="h-36 w-36 rounded-2xl border border-slate-700 bg-slate-900 object-cover md:h-40 md:w-40"
					loading="lazy"
				/>
			</section>

			<section class="mt-10 rounded-2xl border border-slate-800 bg-surface p-8">
				<h2 class="text-2xl font-semibold">Published writing</h2>
				<p class="mt-2 text-muted">Selected articles and blog posts.</p>
				<ul class="mt-6 space-y-4">
					<li>
						<a class="text-accent hover:underline" href="https://devblogs.microsoft.com/premier-developer/container-why-not-app-services/">
							Container? Why not App Services?
						</a>
					</li>
					<li>
						<a class="text-accent hover:underline" href="https://devblogs.microsoft.com/premier-developer/how-microsoft-tracks-santa/">
							How Microsoft Tracks Santa
						</a>
					</li>
				</ul>
			</section>

			<section class="mt-10 grid gap-6 md:grid-cols-2">
				<div class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/40 p-6">
					<p class="text-sm text-muted">Reserved for future content box</p>
				</div>
				<div class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/40 p-6">
					<p class="text-sm text-muted">Reserved for future content box</p>
				</div>
			</section>
		</main>

		<footer class="mx-auto max-w-5xl px-6 pb-10 pt-4 text-sm text-muted">
			&copy; Casey Kriutzfield 1980-{currentYear}
		</footer>
	</body>
</html>
